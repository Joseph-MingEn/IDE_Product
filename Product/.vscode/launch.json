{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Extension (Local AI)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}/apps/vscode-extension"],
      "outFiles": ["${workspaceFolder}/apps/vscode-extension/out/**/*.js"],
      "preLaunchTask": "compile-vscode-extension"
    }
  ]
}
